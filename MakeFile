# Variáveis de Compilação
CC = gcc
CFLAGS = -Wall -Wextra -Werror -std=c11 -g
# CFLAGS += -fsanitize=address -fsanitize=undefined

# Arquivos e Diretórios
ALVO = mini_sgbd
FONTES = principal.c btree.c armazenamento.c
OBJETOS = $(FONTES:.c=.o)

# Alvo Padrão (Compila o executável principal)
all: $(ALVO)

$(ALVO): $(OBJETOS)
	$(CC) $(CFLAGS) -o $@ $^

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# Alvo de Testes Unitários e Funcionais
test: CFLAGS += -DMODO_TESTE
test: clean $(OBJETOS)
	$(CC) $(CFLAGS) -o executor_testes $(OBJETOS)
	./executor_testes --unit

# Alvo de Teste de Estresse (Carga pesada para o relatório)
stress: CFLAGS += -DMODO_ESTRESSE
stress: clean $(OBJETOS)
	$(CC) $(CFLAGS) -o executor_estresse $(OBJETOS)
	./executor_estresse --stress

# Limpeza dos arquivos compilados
clean:
	rm -f $(ALVO) executor_testes executor_estresse *.o *.bin

.PHONY: all test stress clean