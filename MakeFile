# Variáveis de Compilação
CC = gcc
CFLAGS = -Wall -Wextra -Werror -std=c11 -g
# Para habilitar sanitizers nas entregas futuras, você pode descomentar a linha abaixo:
# CFLAGS += -fsanitize=address -fsanitize=undefined

# Arquivos e Diretórios
TARGET = mini_sgbd
SRC = main.c btree.c storage.c
OBJ = $(SRC:.c=.o)

# Alvo Padrão (Compila o executável principal)
all: $(TARGET)

$(TARGET): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $^

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# Alvo de Testes Unitários e Funcionais
test: CFLAGS += -DTEST_MODE
test: clean $(OBJ)
	$(CC) $(CFLAGS) -o test_runner $(OBJ)
	./test_runner --unit

# Alvo de Teste de Estresse (Carga pesada para o relatório)
stress: CFLAGS += -DSTRESS_MODE
stress: clean $(OBJ)
	$(CC) $(CFLAGS) -o stress_runner $(OBJ)
	./stress_runner --stress

# Limpeza dos arquivos compilados
clean:
	rm -f $(TARGET) test_runner stress_runner *.o *.bin

.PHONY: all test stress clean